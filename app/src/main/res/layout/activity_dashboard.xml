<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimary"
        android:elevation="4dp"
        android:title="@string/title_dashboard"
        android:titleTextColor="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── Device Info Card ──────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_device"
                        android:textAppearance="?attr/textAppearanceOverline"
                        android:textColor="@color/colorPrimary" />

                    <TextView
                        android:id="@+id/tvDeviceName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceHeadline6"
                        android:textColor="@color/textPrimary"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvDeviceAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceCaption"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBody2"
                        android:textColor="@color/colorAccent"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Motion & Orientation Card ─────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/section_sensors"
                        android:textAppearance="?attr/textAppearanceOverline"
                        android:textColor="@color/colorPrimary"
                        android:layout_marginBottom="8dp" />

                    <!-- Helmet Upright -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_upright"
                            android:textAppearance="?attr/textAppearanceBody2"
                            android:textColor="@color/textSecondary" />
                        <TextView
                            android:id="@+id/tvUpright"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_value"
                            android:textAppearance="?attr/textAppearanceBody1"
                            android:textColor="@color/textPrimary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginVertical="8dp" />

                    <!-- Accelerometer -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_accel"
                            android:textAppearance="?attr/textAppearanceBody2"
                            android:textColor="@color/textSecondary" />
                        <TextView
                            android:id="@+id/tvAccel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_value"
                            android:textAppearance="?attr/textAppearanceBody1"
                            android:textColor="@color/textPrimary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginVertical="8dp" />

                    <!-- Bike Motion -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_motion"
                            android:textAppearance="?attr/textAppearanceBody2"
                            android:textColor="@color/textSecondary" />
                        <TextView
                            android:id="@+id/tvMotion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_value"
                            android:textAppearance="?attr/textAppearanceBody1"
                            android:textColor="@color/textPrimary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginVertical="8dp" />

                    <!-- Strap Status -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_strap"
                            android:textAppearance="?attr/textAppearanceBody2"
                            android:textColor="@color/textSecondary" />
                        <TextView
                            android:id="@+id/tvStrap"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_value"
                            android:textAppearance="?attr/textAppearanceBody1"
                            android:textColor="@color/textPrimary"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Capacitive Sensors Card ────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/section_capacitive"
                        android:textAppearance="?attr/textAppearanceOverline"
                        android:textColor="@color/colorPrimary"
                        android:layout_marginBottom="8dp" />

                    <!-- Crown -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_crown_cap"
                            android:textAppearance="?attr/textAppearanceBody2"
                            android:textColor="@color/textSecondary" />
                        <TextView
                            android:id="@+id/tvCrownCap"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_value"
                            android:textAppearance="?attr/textAppearanceBody1"
                            android:textColor="@color/textPrimary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginVertical="8dp" />

                    <!-- Forehead -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_forehead_cap"
                            android:textAppearance="?attr/textAppearanceBody2"
                            android:textColor="@color/textSecondary" />
                        <TextView
                            android:id="@+id/tvForeheadCap"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_value"
                            android:textAppearance="?attr/textAppearanceBody1"
                            android:textColor="@color/textPrimary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginVertical="8dp" />

                    <!-- Summary -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_cap_summary"
                            android:textAppearance="?attr/textAppearanceBody2"
                            android:textColor="@color/textSecondary" />
                        <TextView
                            android:id="@+id/tvCapSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_value"
                            android:textAppearance="?attr/textAppearanceBody1"
                            android:textColor="@color/colorAccent"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── ToF Sensors Card ───────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/section_tof"
                        android:textAppearance="?attr/textAppearanceOverline"
                        android:textColor="@color/colorPrimary"
                        android:layout_marginBottom="8dp" />

                    <!-- ToF Left -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_tof_left"
                            android:textAppearance="?attr/textAppearanceBody2"
                            android:textColor="@color/textSecondary" />
                        <TextView
                            android:id="@+id/tvTofLeft"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_value"
                            android:textAppearance="?attr/textAppearanceBody1"
                            android:textColor="@color/textPrimary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginVertical="8dp" />

                    <!-- ToF Right -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_tof_right"
                            android:textAppearance="?attr/textAppearanceBody2"
                            android:textColor="@color/textSecondary" />
                        <TextView
                            android:id="@+id/tvTofRight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_value"
                            android:textAppearance="?attr/textAppearanceBody1"
                            android:textColor="@color/textPrimary"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Interval Selector Card ─────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/section_controls"
                        android:textAppearance="?attr/textAppearanceOverline"
                        android:textColor="@color/colorPrimary"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvIntervalLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/interval_label_default"
                        android:textAppearance="?attr/textAppearanceBody2"
                        android:textColor="@color/textSecondary"
                        android:layout_marginBottom="6dp" />

                    <SeekBar
                        android:id="@+id/seekbarInterval"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:progressTint="@color/colorPrimary"
                        android:thumbTint="@color/colorPrimary" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- ── Bottom control buttons ─────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/surface"
        android:elevation="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_back"
            android:textAllCaps="false"
            android:layout_marginEnd="6dp"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRead"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_read"
            android:textAllCaps="false"
            android:layout_marginHorizontal="6dp"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDisconnect"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_disconnect"
            android:textAllCaps="false"
            android:layout_marginStart="6dp"
            app:cornerRadius="8dp"
            app:strokeColor="@color/colorError" />

    </LinearLayout>

</LinearLayout>
